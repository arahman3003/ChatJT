<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forum Chat</title>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    * {
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background: linear-gradient(135deg, #111827, #020617);
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .chat-container {
      width: 100%;
      max-width: 800px;
      height: 90vh;
      background: rgba(15, 23, 42, 0.95);
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 18px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .chat-header {
      padding: 18px 20px;
      background: rgba(2, 6, 23, 0.9);
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    }

    .chat-header h1 {
      margin: 0;
      font-size: 22px;
    }

    .chat-header p {
      margin: 5px 0 0;
      color: #94a3b8;
      font-size: 14px;
    }

    .name-box {
      display: flex;
      gap: 10px;
      padding: 15px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      background: #0f172a;
    }

    .name-box input {
      flex: 1;
      padding: 12px;
      border: none;
      border-radius: 10px;
      outline: none;
      background: #1e293b;
      color: white;
    }

    .name-box button,
    .chat-form button {
      border: none;
      border-radius: 10px;
      padding: 12px 16px;
      background: #22c55e;
      color: white;
      font-weight: bold;
      cursor: pointer;
    }

    .name-box button:hover,
    .chat-form button:hover {
      background: #16a34a;
    }

    .messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .message {
      background: #1e293b;
      padding: 12px 14px;
      border-radius: 14px;
      max-width: 80%;
      word-wrap: break-word;
    }

    .message.me {
      align-self: flex-end;
      background: #14532d;
    }

    .message .user {
      font-weight: bold;
      color: #38bdf8;
      margin-bottom: 5px;
      font-size: 14px;
    }

    .message.me .user {
      color: #86efac;
    }

    .message .text {
      font-size: 15px;
      line-height: 1.4;
    }

    .message .time {
      margin-top: 6px;
      font-size: 11px;
      color: #94a3b8;
      text-align: right;
    }

    .chat-form {
      display: flex;
      gap: 10px;
      padding: 15px;
      border-top: 1px solid rgba(148, 163, 184, 0.2);
      background: #0f172a;
    }

    .chat-form input {
      flex: 1;
      padding: 12px;
      border: none;
      border-radius: 10px;
      outline: none;
      background: #1e293b;
      color: white;
    }

    .hidden {
      display: none;
    }

    @media (max-width: 600px) {
      .chat-container {
        height: 95vh;
      }

      .message {
        max-width: 95%;
      }

      .chat-header h1 {
        font-size: 18px;
      }
    }
  </style>
</head>

<body>
  <div class="chat-container">
    <div class="chat-header">
      <h1>Forum Chat</h1>
      <p>Chat realtime menggunakan GitHub + Supabase</p>
    </div>

    <div class="name-box" id="nameBox">
      <input type="text" id="usernameInput" placeholder="Masukkan nama kamu..." />
      <button onclick="saveName()">Masuk</button>
    </div>

    <div class="messages" id="messages">
      <p style="color:#94a3b8;text-align:center;">Memuat pesan...</p>
    </div>

    <form class="chat-form" id="chatForm">
      <input type="text" id="messageInput" placeholder="Tulis pesan..." autocomplete="off" />
      <button type="submit">Kirim</button>
    </form>
  </div>

  <script>
    const SUPABASE_URL = "https://wbzxsvhlhbzusyzbjamp.supabase.co";
    const SUPABASE_ANON_KEY = "sb_publishable_55Jwsh0iRWj-BUAvds_MOQ_NEkwcU0p";

    const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    const messagesDiv = document.getElementById("messages");
    const chatForm = document.getElementById("chatForm");
    const messageInput = document.getElementById("messageInput");
    const usernameInput = document.getElementById("usernameInput");
    const nameBox = document.getElementById("nameBox");

    let username = localStorage.getItem("chat_username") || "";

    if (username) {
      nameBox.classList.add("hidden");
    }

    function saveName() {
      const name = usernameInput.value.trim();

      if (!name) {
        alert("Nama tidak boleh kosong");
        return;
      }

      username = name;
      localStorage.setItem("chat_username", username);
      nameBox.classList.add("hidden");
    }

    function formatTime(dateString) {
      const date = new Date(dateString);
      return date.toLocaleString("id-ID", {
        hour: "2-digit",
        minute: "2-digit",
        day: "2-digit",
        month: "short"
      });
    }

    function renderMessage(data) {
      const div = document.createElement("div");
      div.className = "message";

      if (data.username === username) {
        div.classList.add("me");
      }

      div.innerHTML = `
        <div class="user">${escapeHtml(data.username)}</div>
        <div class="text">${escapeHtml(data.message)}</div>
        <div class="time">${formatTime(data.created_at)}</div>
      `;

      messagesDiv.appendChild(div);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function escapeHtml(text) {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    async function loadMessages() {
      const { data, error } = await supabaseClient
        .from("messages")
        .select("*")
        .order("created_at", { ascending: true })
        .limit(100);

      if (error) {
        messagesDiv.innerHTML = `<p style="color:#f87171;">Gagal memuat pesan: ${error.message}</p>`;
        return;
      }

      messagesDiv.innerHTML = "";

      if (data.length === 0) {
        messagesDiv.innerHTML = `<p style="color:#94a3b8;text-align:center;">Belum ada pesan. Jadilah yang pertama!</p>`;
        return;
      }

      data.forEach(renderMessage);
    }

    chatForm.addEventListener("submit", async function(e) {
      e.preventDefault();

      if (!username) {
        alert("Masukkan nama dulu");
        return;
      }

      const message = messageInput.value.trim();

      if (!message) return;

      messageInput.value = "";

      const { error } = await supabaseClient
        .from("messages")
        .insert([
          {
            username: username,
            message: message
          }
        ]);

      if (error) {
        alert("Gagal mengirim pesan: " + error.message);
      }
    });

    supabaseClient
      .channel("messages-channel")
      .on(
        "postgres_changes",
        {
          event: "INSERT",
          schema: "public",
          table: "messages"
        },
        function(payload) {
          const emptyText = messagesDiv.querySelector("p");
          if (emptyText) {
            messagesDiv.innerHTML = "";
          }

          renderMessage(payload.new);
        }
      )
      .subscribe();

    loadMessages();
  </script>
</body>
</html>
